{
  "name": "specwriter",
  "version": "0.5.0",
  "description": "Analyze existing projects and generate comprehensive specifications for AI coding assistants",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "specwriter": "dist/bin/specwriter.js",
    "specwriter-mcp": "dist/bin/specwriter-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/specwriter.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "spec",
    "documentation",
    "ai",
    "analysis",
    "wireframe",
    "component",
    "claude",
    "cursor",
    "copilot"
  ],
  "author": "injaehwang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/injaehwang/specwriter.git"
  },
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "specwriter-core-win32-x64": "0.3.2",
    "specwriter-core-darwin-arm64": "0.3.2",
    "specwriter-core-darwin-x64": "0.3.2",
    "specwriter-core-linux-x64": "0.3.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "ora": "^8.1.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
