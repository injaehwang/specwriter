{
  "name": "specwriter",
  "version": "0.1.0",
  "description": "Analyze existing projects and generate comprehensive specifications for AI coding assistants",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "specwriter": "dist/bin/specwriter.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/specwriter.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["spec", "documentation", "ai", "analysis", "wireframe", "component"],
  "author": "",
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ts-morph": "^24.0.0",
    "glob": "^11.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0"
  }
}
